# Postgres connection settings (used by docker-compose.yml and db/load.py)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analyst_db
POSTGRES_USER=analyst_admin
POSTGRES_PASSWORD=changeme_local_only

# Read-only role used by the application at query time
POSTGRES_RO_USER=analyst_ro
POSTGRES_RO_PASSWORD=changeme_readonly

# Optional: enables LLM-based SQL generation and insight writing.
# Leave unset to run entirely on the deterministic fallback templates.
OPENAI_API_KEY=

# Optional: Slack webhook for pushing insights to a channel
SLACK_WEBHOOK_URL=

# Optional: SMTP settings for emailing reports. If unset, reports are
# written to reports/ instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_RECIPIENT=
